# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# Slot-IDs (aus AdSense-Konsole: Anzeigen → Werbeblöcke → ID kopieren).
# Ohne Slot-ID werden die Ads mit format="auto" ausgeliefert, aber Google
# kann Revenue nicht pro Position tracken. IDs einsetzen für sauberen Report.
NEXT_PUBLIC_ADSENSE_TOP_SLOT=
NEXT_PUBLIC_ADSENSE_MID_SLOT=
NEXT_PUBLIC_ADSENSE_BOTTOM_SLOT=
NEXT_PUBLIC_ADSENSE_STICKY_SLOT=
# Mobile Anchor-Ad (320×50, fixed bottom auf <xl-Viewport).
NEXT_PUBLIC_ADSENSE_ANCHOR_SLOT=

# Newsletter (Brevo)
# `1` aktiviert die NewsletterSignup-Component im Calculator-Layout.
# Ohne Aktivierung wird die Component nicht gerendert.
NEXT_PUBLIC_NEWSLETTER_ENABLED=
# Server-only — niemals NEXT_PUBLIC_*. API v3 Key aus Brevo-Konto.
BREVO_API_KEY=
# Numerische Listen-ID der Newsletter-Liste in Brevo.
BREVO_LIST_ID=
# (Optional) DOI-Template-ID. Wenn gesetzt, wird der DOI-Endpunkt genutzt.
BREVO_DOI_TEMPLATE=
